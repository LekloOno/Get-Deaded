[layer_names]

3d_render/layer_1="Main"
3d_render/layer_2="UI"

[physics]

common/physics_jitter_fix=0.0
3d/physics_engine="Jolt Physics"
common/physics_interpolation=true
jolt_physics_3d/simulation/areas_detect_static_bodies=true

[rendering]

shader_compiler/shader_cache/enabled=false
environment/ssao/quality=0
environment/ssao/adaptive_target=1.0
environment/ssil/adaptive_target=1.0
anti_aliasing/screen_space_roughness_limiter/enabled=false
occlusion_culling/use_occlusion_culling=true
lights_and_shadows/positional_shadow/atlas_size=2048

[shader_globals]

enemy_color={
"type": "color",
"value": Color(1, 0, 0.20784314, 1)
}
enemy_outlines_opacity={
"type": "float",
"value": 1.0
}
enemy_outlines_thickness={
"type": "float",
"value": 3.0
}
